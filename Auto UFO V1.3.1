local function switchTab(t)
    currentTab=t
    mainTab.Visible=false lootTab2.Visible=false credTab2.Visible=false settTab.Visible=false
    tabMainBtn.BackgroundColor3=Color3.fromRGB(30,30,50) tabMainBtn.TextColor3=Color3.fromRGB(160,160,200)
    tabLootBtn.BackgroundColor3=Color3.fromRGB(30,30,50) tabLootBtn.TextColor3=Color3.fromRGB(160,160,200)
    tabCredBtn.BackgroundColor3=Color3.fromRGB(30,30,50) tabCredBtn.TextColor3=Color3.fromRGB(160,160,200)
    tabSettBtn.BackgroundColor3=Color3.fromRGB(30,30,50) tabSettBtn.TextColor3=Color3.fromRGB(160,160,200)
    if t=="main" then mainTab.Visible=true tabMainBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabMainBtn.TextColor3=Color3.new(1,1,1)
    elseif t=="loot" then lootTab2.Visible=true tabLootBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabLootBtn.TextColor3=Color3.new(1,1,1)
    elseif t=="credits" then credTab2.Visible=true tabCredBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabCredBtn.TextColor3=Color3.new(1,1,1)
    elseif t=="settings" then settTab.Visible=true tabSettBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabSettBtn.TextColor3=Color3.new(1,1,1)
    end
    if t=="loot" then refreshLootHistory() end
end
tabMainBtn.MouseButton1Click:Connect(function() if currentTab=="settings" then switchTab("main") elseif currentTab=="main" then switchTab("loot") elseif currentTab=="loot" then switchTab("credits") else switchTab("main") end end)
