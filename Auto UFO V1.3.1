topBar.InputBegan:Connect(function(input) if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not resizing then dragging=true dragStartPos=input.Position startPanelPos=panel.Position end end)
panel.InputBegan:Connect(function(input) if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not resizing then dragging=true dragStartPos=input.Position startPanelPos=panel.Position end end)
contentArea.InputBegan:Connect(function(input) if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not resizing then dragging=true dragStartPos=input.Position startPanelPos=panel.Position end end)
UIS.InputChanged:Connect(function(input) if dragging and not resizing and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then local d=input.Position-dragStartPos panel.Position=UDim2.new(startPanelPos.X.Scale,startPanelPos.X.Offset+d.X,startPanelPos.Y.Scale,startPanelPos.Y.Offset+d.Y) end end)
UIS.InputEnded:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then dragging=false end end)

