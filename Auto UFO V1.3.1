tabSettBtn.MouseButton1Click:Connect(function() if currentTab=="settings" then switchTab("main") else switchTab("settings") end end)
settingsBtn.MouseButton1Click:Connect(function() if currentTab=="settings" then switchTab("main") else switchTab("settings") end end)

