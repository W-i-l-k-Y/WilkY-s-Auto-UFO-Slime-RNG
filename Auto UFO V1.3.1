local ufoCli = ufoEV:WaitForChild("UfoEventServiceClient")
local zonesMod = src:WaitForChild("Game"):WaitForChild("Items"):WaitForChild("Zones")

local UfoEventServiceClient = require(ufoCli)
local Zones = require(zonesMod)
local stateSource = UfoEventServiceClient:getStateSource()
local isAutoTPEnabled = true
local lastTeleportedZoneId = nil
local savedReturnZoneId = nil
local wasIdle = true
local currentFontSize = 10

local lootHistory = {}
local lootStats = {food=0, boost=0, fruit=0, specialDice=0, total=0}
local allTextLabels = {}

local lootCliMod = feat:FindFirstChild("Loot")
local LootServiceClient = nil
if lootCliMod then
    local lsc = lootCliMod:FindFirstChild("LootServiceClient")
    if lsc then
        LootServiceClient = require(lsc)
        local orig = LootServiceClient.requestCollect
        if orig then
            LootServiceClient.requestCollect = function(self, uid)
                local ld, ldef = nil, nil
                if self.lootById and self.lootById[uid] then
                    ld = self.lootById[uid].data
                    ldef = self.lootById[uid].definition
                end
                local result = orig(self, uid)
                if result and ld and ldef then
                    local en = {
                        name = ldef.name or "Unknown",
                        kind = ldef.kind or "unknown",
                        zoneId = stateSource().zoneId,
                        time = os.date("%H:%M:%S"),
                        timestamp = tick(),
                    }
                    table.insert(lootHistory, en)
                    lootStats.total = lootStats.total + 1
                    if lootStats[en.kind] then lootStats[en.kind] = lootStats[en.kind] + 1 end
                    if currentTab == "loot" then refreshLootHistory() end
                end
                return result
            end
        end
    end
end

local function getHRP()
    local c = player.Character
    if not c then c = player.CharacterAdded:Wait() end
    if c then return c:WaitForChild("HumanoidRootPart", 8) end return nil
end

local function getZoneTP(zid)
    if not zid then return nil end
    local f = workspace.Zones:FindFirstChild(tostring(zid))
    if not f then return nil end
    local poi = f:FindFirstChild("POI")
    if not poi then return nil end
    local hb = poi:FindFirstChild("Hitbox")
    if hb then return hb.Position + Vector3.new(0,8,0) end
    local bp = poi:FindFirstChild("Baseplate")
    if bp then return bp.Position + Vector3.new(0,8,0) end return nil
end

local function doTeleport(pos)
    local hrp = getHRP()
    if not hrp then return false end
    local hum = player.Character:FindFirstChildWhichIsA("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return pcall(function() hrp.CFrame = CFrame.new(pos) end)
end

local function getPlayerZoneId()
    local c = player.Character
    if not c then return nil end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local pp = hrp.Position
    for _, zf in pairs(workspace.Zones:GetChildren()) do
        if zf:IsA("Model") or zf:IsA("Folder") then
            local poi = zf:FindFirstChild("POI")
            if poi then
                local hb = poi:FindFirstChild("Hitbox")
                if hb and (pp-hb.Position).Magnitude < 100 then
                    return tonumber(zf.Name)
                end
            end
        end
    end return nil
end

local function getItemColor(k)
    if k=="food" then return Color3.fromRGB(100,255,150)
    elseif k=="boost" then return Color3.fromRGB(255,200,100)
    elseif k=="fruit" then return Color3.fromRGB(200,100,255)
    elseif k=="specialDice" then return Color3.fromRGB(100,200,255)
    else return Color3.fromRGB(200,200,200) end
end

local function getItemEmoji(k)
    if k=="food" then return "F"
    elseif k=="boost" then return "B"
    elseif k=="fruit" then return "P"
    elseif k=="specialDice" then return "D"
    else return "?" end
end

local function scaled(baseSize)
    return math.floor(baseSize * (currentFontSize / 10))
end

local function applyFontSize()
    for _, entry in ipairs(allTextLabels) do
        if entry then entry.label.TextSize = scaled(entry.baseSize) end
    end
end

local function trackFont(label, baseSize)
    table.insert(allTextLabels, {label=label, baseSize=baseSize})
    label.TextSize = scaled(baseSize)
end

