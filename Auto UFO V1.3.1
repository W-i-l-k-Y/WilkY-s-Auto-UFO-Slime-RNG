function refreshLootHistory()
    for _,f in ipairs(lootEntryFrames) do f:Destroy() end lootEntryFrames={}
    for idx=#lootHistory,1,-1 do
        local e=lootHistory[idx]
        local row=Instance.new("Frame") row.Size=UDim2.new(1,-4,0,18) row.BackgroundColor3=Color3.fromRGB(30,30,45) row.LayoutOrder=#lootHistory-idx+1 row.Parent=ls Instance.new("UICorner",row).CornerRadius=UDim.new(0,3)
        local tlb=Instance.new("TextLabel") tlb.Size=UDim2.new(0.22,0,1,0) tlb.Position=UDim2.new(0,3,0,0) tlb.BackgroundTransparency=1 tlb.Text=e.time tlb.TextColor3=Color3.fromRGB(140,140,160) tlb.Font=Enum.Font.Gotham tlb.TextXAlignment=Enum.TextXAlignment.Left tlb.Parent=row trackFont(tlb,9)
        local kdb=Instance.new("TextLabel") kdb.Size=UDim2.new(0.08,0,1,0) kdb.Position=UDim2.new(0.22,0,0,0) kdb.BackgroundTransparency=1 kdb.Text=getItemEmoji(e.kind) kdb.TextColor3=getItemColor(e.kind) kdb.Font=Enum.Font.GothamBold kdb.TextXAlignment=Enum.TextXAlignment.Center kdb.Parent=row trackFont(kdb,10)
        local nlb=Instance.new("TextLabel") nlb.Size=UDim2.new(0.6,0,1,0) nlb.Position=UDim2.new(0.3,0,0,0) nlb.BackgroundTransparency=1 nlb.Text=e.name nlb.TextColor3=getItemColor(e.kind) nlb.Font=Enum.Font.GothamMedium nlb.TextXAlignment=Enum.TextXAlignment.Left nlb.TextTruncate=Enum.TextTruncate.AtEnd nlb.Parent=row trackFont(nlb,9)
        if e.zoneId then local zlb=Instance.new("TextLabel") zlb.Size=UDim2.new(0.1,0,1,0) zlb.Position=UDim2.new(0.9,0,0,0) zlb.BackgroundTransparency=1 zlb.Text="Z"..tostring(e.zoneId) zlb.TextColor3=Color3.fromRGB(100,100,130) zlb.Font=Enum.Font.Gotham zlb.TextXAlignment=Enum.TextXAlignment.Right zlb.Parent=row trackFont(zlb,8) end
        table.insert(lootEntryFrames,row)
    end
    tl.Text="Total: "..lootStats.total fl.Text="Food: "..lootStats.food bl.Text="Boost: "..lootStats.boost frl.Text="Fruit: "..lootStats.fruit dl.Text="Dice: "..lootStats.specialDice
end
clb.MouseButton1Click:Connect(function() lootHistory={} lootStats={food=0,boost=0,fruit=0,specialDice=0,total=0} refreshLootHistory() end)

