function refreshLootHistory()
    for _, f in ipairs(lootEntryFrames) do f:Destroy() end
    lootEntryFrames = {}
    for idx = #lootHistory, 1, -1 do
        local e = lootHistory[idx]
        local row = Instance.new("Frame") row.Size = UDim2.new(1,-4,0,18) row.BackgroundColor3 = Color3.fromRGB(30,30,45) row.LayoutOrder = #lootHistory-idx+1 row.Parent = lootScroll Instance.new("UICorner",row).CornerRadius=UDim.new(0,3)
        local tl = Instance.new("TextLabel") tl.Size = UDim2.new(0.22,0,1,0) tl.Position = UDim2.new(0,3,0,0) tl.BackgroundTransparency = 1 tl.Text = e.time tl.TextColor3 = Color3.fromRGB(140,140,160) tl.Font = Enum.Font.Gotham tl.TextXAlignment = Enum.TextXAlignment.Left tl.Parent = row trackFont(tl,9)
        local kd = Instance.new("TextLabel") kd.Size = UDim2.new(0.08,0,1,0) kd.Position = UDim2.new(0.22,0,0,0) kd.BackgroundTransparency = 1 kd.Text = getItemEmoji(e.kind) kd.TextColor3 = getItemColor(e.kind) kd.Font = Enum.Font.GothamBold kd.TextXAlignment = Enum.TextXAlignment.Center kd.Parent = row trackFont(kd,10)
        local nl = Instance.new("TextLabel") nl.Size = UDim2.new(0.6,0,1,0) nl.Position = UDim2.new(0.3,0,0,0) nl.BackgroundTransparency = 1 nl.Text = e.name nl.TextColor3 = getItemColor(e.kind) nl.Font = Enum.Font.GothamMedium nl.TextXAlignment = Enum.TextXAlignment.Left nl.TextTruncate = Enum.TextTruncate.AtEnd nl.Parent = row trackFont(nl,9)
        if e.zoneId then local zl = Instance.new("TextLabel") zl.Size = UDim2.new(0.1,0,1,0) zl.Position = UDim2.new(0.9,0,0,0) zl.BackgroundTransparency = 1 zl.Text = "Z"..tostring(e.zoneId) zl.TextColor3 = Color3.fromRGB(100,100,130) zl.Font = Enum.Font.Gotham zl.TextXAlignment = Enum.TextXAlignment.Right zl.Parent = row trackFont(zl,8) end
        table.insert(lootEntryFrames, row)
    end
    totalLabel.Text = "Total: "..lootStats.total
    foodLabel.Text = "Food: "..lootStats.food
    boostLabel.Text = "Boost: "..lootStats.boost
    fruitLabel.Text = "Fruit: "..lootStats.fruit
    diceLabel.Text = "Dice: "..lootStats.specialDice
end
clearLootBtn.MouseButton1Click:Connect(function() lootHistory={} lootStats={food=0,boost=0,fruit=0,specialDice=0,total=0} refreshLootHistory() end)

