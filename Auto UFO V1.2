local currentTab = "main"
local function switchTab(t)
    currentTab = t
    mainTab.Visible = false lootTab.Visible = false credTab.Visible = false settingsTab.Visible = false
    tabMainBtn.BackgroundColor3 = Color3.fromRGB(30,30,50) tabMainBtn.TextColor3 = Color3.fromRGB(160,160,200)
    tabLootBtn.BackgroundColor3 = Color3.fromRGB(30,30,50) tabLootBtn.TextColor3 = Color3.fromRGB(160,160,200)
    tabCredBtn.BackgroundColor3 = Color3.fromRGB(30,30,50) tabCredBtn.TextColor3 = Color3.fromRGB(160,160,200)
    if t=="main" then mainTab.Visible=true tabMainBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabMainBtn.TextColor3=Color3.new(1,1,1)
    elseif t=="loot" then lootTab.Visible=true tabLootBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabLootBtn.TextColor3=Color3.new(1,1,1)
    elseif t=="credits" then credTab.Visible=true tabCredBtn.BackgroundColor3=Color3.fromRGB(50,50,80) tabCredBtn.TextColor3=Color3.new(1,1,1)
    elseif t=="settings" then settingsTab.Visible=true tabMainBtn.BackgroundColor3=Color3.fromRGB(50,50,60) tabMainBtn.TextColor3=Color3.fromRGB(255,200,100)
    end
    if t=="loot" then refreshLootHistory() end
end

tabMainBtn.MouseButton1Click:Connect(function()
    if currentTab=="settings" then switchTab("main") elseif currentTab=="main" then switchTab("loot") elseif currentTab=="loot" then switchTab("credits") else switchTab("main") end
end)
tabLootBtn.MouseButton1Click:Connect(function()
    if currentTab=="loot" then switchTab("credits") else switchTab("loot") end
end)
tabCredBtn.MouseButton1Click:Connect(function()
    if currentTab=="credits" then switchTab("settings") elseif currentTab=="settings" then switchTab("main") else switchTab("credits") end
end)
settingsBtn.MouseButton1Click:Connect(function()
    if currentTab=="settings" then switchTab("main") else switchTab("settings") end
end)
closeSetBtn.MouseButton1Click:Connect(function() switchTab("main") end)

