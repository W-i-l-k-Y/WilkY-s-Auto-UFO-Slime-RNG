task.spawn(function()
    while true do
        task.wait(2)
        local ok, state = pcall(function() return stateSource() end)
        if not ok or not state then status.Text="Could not read UFO state." continue end
        local curZone = getPlayerZoneId()
        if curZone then local zn="?" pcall(function() if Zones.hasZone(curZone) then zn=Zones.getZone(curZone).name end end) zoneInfo.Text="Current zone: "..zn else zoneInfo.Text="Current zone: unknown" end
        if savedReturnZoneId then local rn="?" pcall(function() if Zones.hasZone(savedReturnZoneId) then rn=Zones.getZone(savedReturnZoneId).name end end) returnInfo.Text="Return zone: "..rn else returnInfo.Text="Return zone: none" end
        if not isAutoTPEnabled then status.Text="Auto-TP OFF." continue end
        local isIdle = (state.phase=="idle")
        if not isIdle and wasIdle then local cz=getPlayerZoneId() if cz then savedReturnZoneId=cz local zn="?" pcall(function() if Zones.hasZone(cz) then zn=Zones.getZone(cz).name end end) print("[WilkY's Auto UFO] Saved: "..zn) end lastTeleportedZoneId=nil end
        if isIdle and not wasIdle then if savedReturnZoneId then local rpos=getZoneTP(savedReturnZoneId) if rpos then task.delay(3,function() if doTeleport(rpos) then local zn="?" pcall(function() if Zones.hasZone(savedReturnZoneId) then zn=Zones.getZone(savedReturnZoneId).name end end) print("[WilkY's Auto UFO] Returned to "..zn) end end) status.Text="Event ended. Returning in 3s..." end end lastTeleportedZoneId=nil end
        wasIdle=isIdle
        if isIdle then if state.nextEventStartTime then local rem=math.max(0,state.nextEventStartTime-os.time()) status.Text="Next UFO in "..math.floor(rem/60).."m "..(rem%60).."s" else status.Text="Waiting..." end
        else local zId=state.zoneId local zn="?" pcall(function() if zId and Zones.hasZone(zId) then zn=Zones.getZone(zId).name end end)
            local target=nil if state.hoverPosition then target=state.hoverPosition+Vector3.new(0,5,0) elseif zId then target=getZoneTP(zId) end
            if target and zId~=lastTeleportedZoneId then if doTeleport(target) then lastTeleportedZoneId=zId status.Text="Teleported to "..zn.." ["..state.phase.."]" else status.Text="TP failed." end
            elseif target and zId==lastTeleportedZoneId then status.Text=zn.." ["..state.phase.."]"
            else status.Text=zn.." ["..state.phase.."] (no pos)" end
        end
    end
end)

