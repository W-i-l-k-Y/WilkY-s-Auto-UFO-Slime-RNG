local resizer = Instance.new("TextButton") resizer.Size = UDim2.new(0,16,0,16) resizer.Position = UDim2.new(1,-18,1,-18) resizer.BackgroundColor3 = Color3.fromRGB(60,60,90) resizer.Text = "" resizer.BorderSizePixel = 0 resizer.ZIndex = 50 resizer.Parent = panel
Instance.new("UICorner",resizer).CornerRadius = UDim.new(0,4)
local resizing, resizeStart, startSize
resizer.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then resizing=true resizeStart=input.Position startSize=panel.Size end
end)
UserInputService.InputChanged:Connect(function(input)
    if resizing and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then
        local d = input.Position - resizeStart
        local nw=math.clamp(startSize.X.Offset+d.X,200,600) local nh=math.clamp(startSize.Y.Offset+d.Y,160,600)
        panel.Size=UDim2.new(0,nw,0,nh) wLbl.Text="Width: "..nw hLbl.Text="Height: "..nh sizeDisp.Text="Size: "..nw.."x"..nh
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then resizing=false end
end)

local dragging, dragStartPos, startPanelPos
topBar.InputBegan:Connect(function(input)
    if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not resizing then dragging=true dragStartPos=input.Position startPanelPos=panel.Position end
end)
panel.InputBegan:Connect(function(input)
    if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not resizing then dragging=true dragStartPos=input.Position startPanelPos=panel.Position end
end)
contentArea.InputBegan:Connect(function(input)
    if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not resizing then dragging=true dragStartPos=input.Position startPanelPos=panel.Position end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and not resizing and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then
        local d = input.Position - dragStartPos panel.Position = UDim2.new(startPanelPos.X.Scale,startPanelPos.X.Offset+d.X,startPanelPos.Y.Scale,startPanelPos.Y.Offset+d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then dragging=false end
end)

