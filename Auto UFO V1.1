local function getHRP()
    local char = player.Character
    if not char then char = player.CharacterAdded:Wait() end
    if char then return char:WaitForChild("HumanoidRootPart", 8) end
    return nil
end

local function getZoneTP(zoneId)
    if not zoneId then return nil end
    local folder = workspace.Zones:FindFirstChild(tostring(zoneId))
    if not folder then return nil end
    local poi = folder:FindFirstChild("POI")
    if not poi then return nil end
    local hitbox = poi:FindFirstChild("Hitbox")
    if hitbox then return hitbox.Position + Vector3.new(0, 8, 0) end
    local bp = poi:FindFirstChild("Baseplate")
    if bp then return bp.Position + Vector3.new(0, 8, 0) end
    return nil
end

local function doTeleport(pos)
    local hrp = getHRP()
    if not hrp then return false end
    local hum = player.Character:FindFirstChildWhichIsA("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return pcall(function() hrp.CFrame = CFrame.new(pos) end)
end

local function getPlayerZoneId()
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local pp = hrp.Position
    for _, zf in pairs(workspace.Zones:GetChildren()) do
        if zf:IsA("Model") or zf:IsA("Folder") then
            local poi = zf:FindFirstChild("POI")
            if poi then
                local hb = poi:FindFirstChild("Hitbox")
                if hb and (pp - hb.Position).Magnitude < 100 then
                    return tonumber(zf.Name)
                end
            end
        end
    end
    return nil
end

