-- ===== TAB SWITCHING =====
local currentTab = "main"

local function switchTab(t)
    currentTab = t
    mainTab.Visible = false
    credTab.Visible = false
    settingsTab.Visible = false
    tabMainBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    tabMainBtn.TextColor3 = Color3.fromRGB(160, 160, 200)
    tabCredBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    tabCredBtn.TextColor3 = Color3.fromRGB(160, 160, 200)
    if t == "main" then
        mainTab.Visible = true
        tabMainBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 80)
        tabMainBtn.TextColor3 = Color3.new(1, 1, 1)
    elseif t == "credits" then
        credTab.Visible = true
        tabCredBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 80)
        tabCredBtn.TextColor3 = Color3.new(1, 1, 1)
    elseif t == "settings" then
        settingsTab.Visible = true
        tabMainBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
        tabMainBtn.TextColor3 = Color3.fromRGB(255, 200, 100)
    end
end

tabMainBtn.MouseButton1Click:Connect(function()
    if currentTab == "settings" then switchTab("main")
    elseif currentTab == "main" then switchTab("credits")
    else switchTab("main") end
end)

tabCredBtn.MouseButton1Click:Connect(function()
    if currentTab == "settings" then switchTab("credits")
    else switchTab("settings") end
end)

settingsBtn.MouseButton1Click:Connect(function()
    if currentTab == "settings" then switchTab("main") else switchTab("settings") end
end)

closeSetBtn.MouseButton1Click:Connect(function() switchTab("main") end)

