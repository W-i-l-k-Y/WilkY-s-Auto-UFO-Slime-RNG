-- ===== RESIZE HANDLE =====
local resizer = Instance.new("TextButton")
resizer.Size = UDim2.new(0, 16, 0, 16)
resizer.Position = UDim2.new(1, -18, 1, -18)
resizer.BackgroundColor3 = Color3.fromRGB(60, 60, 90)
resizer.Text = ""
resizer.BorderSizePixel = 0
resizer.ZIndex = 50
resizer.Parent = panel
Instance.new("UICorner", resizer).CornerRadius = UDim.new(0, 4)

local resizing, resizeStart, startSize
resizer.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        resizeStart = input.Position
        startSize = panel.Size
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeStart
        local nw = math.clamp(startSize.X.Offset + delta.X, 180, 600)
        local nh = math.clamp(startSize.Y.Offset + delta.Y, 150, 600)
        panel.Size = UDim2.new(0, nw, 0, nh)
        wLabel.Text = "Width: " .. nw
        hLabel.Text = "Height: " .. nh
        sizeLabel.Text = "Current: " .. nw .. " x " .. nh
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = false
    end
end)

-- ===== FULL PANEL DRAG =====
-- Strategy: topBar (ZIndex 30) is always draggable.
-- panel background (ZIndex 1) is draggable but buttons (ZIndex 15+) consume their own clicks.
-- Since child InputBegan fires BEFORE parent, buttons block the panel drag automatically.

local dragging, dragStartPos, startPanelPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not resizing then
            dragging = true
            dragStartPos = input.Position
            startPanelPos = panel.Position
        end
    end
end)

panel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not resizing then
            dragging = true
            dragStartPos = input.Position
            startPanelPos = panel.Position
        end
    end
end)

contentArea.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not resizing then
            dragging = true
            dragStartPos = input.Position
            startPanelPos = panel.Position
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and not resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPos
        panel.Position = UDim2.new(
            startPanelPos.X.Scale, startPanelPos.X.Offset + delta.X,
            startPanelPos.Y.Scale, startPanelPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

